{
    "compilerOptions": {
        "target": "ES6",
        "module": "CommonJS",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "typeRoots": ["./node_modules/@types"],
        "types": ["jest", "node"]
    },

    "include": ["src/**/*"],
    "exclude": ["node_modules", "**/*jest.config.ts"]
}
